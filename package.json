{
  "name": "com.spresenter.raffle",
  "version": "0.3.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build:code": "vite build --config vite.code.config.ts",
    "build:ui": "vite build --config vite.ui.config.ts",
    "build": "npm run build:code && npm run build:ui",
    "package": "npm run build && node scripts/package.mjs",
    "dev": "concurrently -k \"npm:watch:code\" \"npm:watch:ui\"",
    "watch:code": "vite build --watch --config vite.code.config.ts",
    "watch:ui": "vite build --watch --config vite.ui.config.ts"
  },
  "dependencies": {
    "@spresenter/plugin-sdk": "file:sdk/spresenter-plugin-sdk.tgz",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "adm-zip": "^0.5.17",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0"
  }
}
